GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:4174/api/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_TIME_ZONE=Europe/Moscow
GOOGLE_INCLUDE_ALL_CALENDARS=true
GOOGLE_INCLUDE_TASKS=true
GOOGLE_REQUEST_TIMEOUT_MS=12000
GOOGLE_TASK_HISTORY_LIMIT=500
LEVTIA_APP_ORIGIN=http://127.0.0.1:5173

MAX_BOT_TOKEN=
# Current fallback. Treat this as the Stavropolskaya studio chat until split chats are configured.
MAX_REPORT_CHAT_ID=
MAX_REPORT_CHAT_ID_STAVROPOLSKAYA=
MAX_REPORT_CHAT_ID_MACHUGI=
MAX_REQUEST_TIMEOUT_MS=12000
MAX_API_BASE=https://platform-api.max.ru
CRON_SECRET=
MAX_REMINDER_RETENTION_DAYS=20
LEVITA_CALLS_SYNC_TOKEN=
APP_STATE_BACKUP_RETENTION_DAYS=20
APP_STATE_BACKUP_MAX_ROWS=50

# Storage backend.
# Production path: Supabase Postgres through Prisma. SQLite/app_state are only legacy fallback modes.
LEVTIA_STORAGE_DRIVER=supabase
LEVTIA_DATA_MODE=prisma
LEVTIA_SQLITE_PATH=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-eu-west-2.pooler.supabase.com:5432/postgres"
