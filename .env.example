GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:4174/api/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_TIME_ZONE=Europe/Moscow
GOOGLE_INCLUDE_ALL_CALENDARS=true
GOOGLE_INCLUDE_TASKS=true
GOOGLE_REQUEST_TIMEOUT_MS=12000
GOOGLE_TASK_HISTORY_LIMIT=500
LEVTIA_APP_ORIGIN=http://127.0.0.1:5173

MAX_BOT_TOKEN=
# Current fallback. Treat this as the Stavropolskaya studio chat until split chats are configured.
MAX_REPORT_CHAT_ID=
MAX_REPORT_CHAT_ID_STAVROPOLSKAYA=
MAX_REPORT_CHAT_ID_MACHUGI=
MAX_REQUEST_TIMEOUT_MS=12000
MAX_API_BASE=https://platform-api.max.ru

# Storage backend.
# sqlite keeps the current local data/data/levtia-library.sqlite flow.
# supabase stores /api/state and Google OAuth records in Supabase tables.
LEVTIA_STORAGE_DRIVER=sqlite
LEVTIA_SQLITE_PATH=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
